{
  "expo": {
    "name": "Iran e-ID",
    "slug": "iran-e-id",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0B2545"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "org.iran.eid"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0B2545",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png"
      },
      "package": "org.iran.eid"
    },
    "plugins": [
      "expo-secure-store",
      ["expo-image-picker", { "photosPermission": "Allow Iran e-ID to access your photos." }],
      ["expo-local-authentication", { "faceIDPermission": "Allow Iran e-ID to use Face ID." }]
    ]
  }
}
